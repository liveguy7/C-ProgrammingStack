#include <iostream>
#include <string>

using namespace std;

//Stack Implementation using C++
class Stack {
    private: int top;
    private: int arr[5];
    
    public: Stack() {
        top = -1;
        for(int i=0; i<5; i++) {
            arr[i] = 0;
        }
    }
    
    public: bool isEmpty() {
        if(top==-1)
            return true;
        else
            return false;
    }
    
    public: bool isFull() {
        if(top==4)
            return true;
        else
            return false;
    }
    
    public: void push(int val) {
        if(isFull()){
            cout << "Stack Overflow" << endl;
        }
        else {
            top++;
            arr[top] = val;
        }
    }
    
    public: int pop() {
        if(isEmpty()) {
            cout << "Stack Underflow" << endl;
            return 0;
        }
        else {
            int popvalue = arr[top];
            arr[top] = 0;
            top--;
            return popvalue;
        }
    }
    
    public: int count() {
        return top + 1;
    }
    
    public: int peek(int pos) {
        if(isEmpty()) {
            cout << "Stack Underflow" << endl;
            return 0;
        }
        else {
            return arr[pos];
        }
    }
    
    public: void change(int pos, int val) {
        arr[pos] = val;
        cout << "Value changed at " << pos << endl;
    }
    
    public: void display() {
        cout << "All Values in the Stack Are: " << endl;
        for(int i=4; i>=0; i--) {
            cout << arr[i] << endl;
        }
    }
    
};


int main() {
    Stack *s1 = new Stack();
    int option,position,value;
    
    do {
        cout << "Choose an Option: " << endl;
        cout << "1. Push" << endl;
        cout << "2. Pop" << endl;
        cout << "3. Check Container" << endl;
        cout << "4. Full Container" << endl;
        cout << "5. See Value" << endl;
        cout << "6. Total Items" << endl;
        cout << "7. Modify" << endl;
        cout << "8. Display" << endl;
        cout << "9. Clear" << endl;
        cout << "0. Exit" << endl;
        cout << "Waiting on Selection.. ";
        cin >> option;
        switch(option) {
            case 0:
                break;
            case 1: 
                cout << "Enter an item to push in the Stack ";
                cin >> value;
                s1->push(value);
                break;
            case 2:
                cout << "Remove a value ";
                cout << s1->pop() << endl;
            case 3:;
                if(s1->isEmpty()) 
                    cout << "Stack is Empty" << endl;
                else
                    cout << "Stack is Not Empty" << endl;
                break;
            case 4:
                if(s1->isFull())
                    cout << "Stack is Full" << endl;
                else
                    cout << "Stack is Not Full" << endl;
                break;
            case 5:
                cout << "Enter position of Item to See ";
                cin >> position;
                cout << "Peek Function Called " << position << endl;
                cout << "Value at pos " << s1->peek(position) << endl;
                break;
            case 6:
                cout << "Amount of Items " << s1->count() << endl;
                break;
            case 7:
            cout << "Change Function Called " << endl;
            cout << "Enter position item you want to change: ";
            cin >> position;
            cout << endl;
            cout << "Enter value you want to change: ";
            cin >> value;
            s1->change(position,value);
            break;
            case 8:
                s1->display();
                break;
            case 9:
                system("cls");
                break;
            default:
                cout << "Enter a Proper option or press 0 to exit ";
                break;
            
        }
        
    }
    while(option != 0);

    
    return 0;
}






